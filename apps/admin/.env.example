# Base URL of the Teeko backend API
NEXT_PUBLIC_API_URL=http://localhost:8000

# Dev-only: the seeded admin user id sent via X-Teeko-User so the backend's development auth bypass resolves an admin role
NEXT_PUBLIC_ADMIN_DEV_USER=00000000-0000-0000-0000-0000000000a0

# Google Maps JS API key — required by the live-trips map (app/(panel)/trips/live)
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=
