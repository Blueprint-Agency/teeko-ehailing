{
  "name": "@teeko/rider",
  "version": "0.1.0",
  "private": true,
  "main": "expo-router/entry",
  "scripts": {
    "dev": "expo start",
    "dev:web": "expo start --web",
    "android": "expo start --android",
    "ios": "expo start --ios",
    "build": "expo export --platform android --platform ios",
    "build:android:apk": "eas build -p android --profile preview",
    "build:android:dev": "eas build -p android --profile development",
    "build:ios:sim": "eas build -p ios --profile simulator",
    "build:ios:device": "eas build -p ios --profile preview",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@expo-google-fonts/nunito": "^0.2.3",
    "@expo/metro-runtime": "~6.1.2",
    "@gorhom/bottom-sheet": "^5.0.6",
    "@react-native-async-storage/async-storage": "2.2.0",
    "@teeko/api": "workspace:*",
    "@teeko/i18n": "workspace:*",
    "@teeko/maps": "workspace:*",
    "@teeko/shared": "workspace:*",
    "@teeko/ui": "workspace:*",
    "expo": "~54.0.0",
    "expo-constants": "~18.0.13",
    "expo-font": "~14.0.11",
    "expo-haptics": "~15.0.8",
    "expo-image": "~3.0.11",
    "expo-linking": "~8.0.11",
    "expo-localization": "~17.0.8",
    "expo-location": "~19.0.8",
    "expo-notifications": "~0.32.16",
    "expo-router": "~6.0.23",
    "expo-status-bar": "~3.0.9",
    "i18next": "^23.16.5",
    "lucide-react-native": "^0.468.0",
    "nativewind": "^4.1.23",
    "react": "19.1.0",
    "react-dom": "19.1.0",
    "react-i18next": "^15.1.3",
    "react-native": "0.81.5",
    "react-native-gesture-handler": "~2.28.0",
    "react-native-maps": "1.20.1",
    "react-native-reanimated": "~4.1.7",
    "react-native-safe-area-context": "5.6.2",
    "react-native-screens": "~4.16.0",
    "react-native-svg": "15.12.1",
    "react-native-web": "~0.21.2",
    "zustand": "^5.0.2"
  },
  "devDependencies": {
    "@teeko/config": "workspace:*",
    "@types/react": "~19.1.10",
    "tailwindcss": "^3.4.17",
    "typescript": "^5.9.2"
  }
}
