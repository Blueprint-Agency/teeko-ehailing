# Rider app environment — copy to `.env` and fill in.
# Only EXPO_PUBLIC_* vars are exposed to the client bundle.

# Clerk (auth) — publishable key from the Clerk dashboard.
EXPO_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_...

# Google Maps — used by react-native-maps (native build only).
GOOGLE_MAPS_API_KEY=

# Backend API base URL. Android emulator → host is 10.0.2.2.
EXPO_PUBLIC_API_URL=http://10.0.2.2:3000

# Stripe publishable key (pk_test_… / pk_live_…). Safe to expose to the client;
# card data is tokenized on-device by @stripe/stripe-react-native (PCI SAQ-A).
EXPO_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...
