# --- Server ---
NODE_ENV=development
PORT=3000
LOG_LEVEL=debug

# --- Database ---
# Local docker-compose maps host 5500 -> container 5432.
DATABASE_URL=postgres://teeko:teeko@localhost:5500/teeko

# --- Redis ---
# Local docker-compose runs redis on 6379.
REDIS_URL=redis://localhost:6379

# --- Commission & fees ---
COMMISSION_RATE=0.10
CANCELLATION_FEE_CENTS=300

# --- Auth0 (placeholder for v1.0) ---
AUTH0_DOMAIN=
AUTH0_AUDIENCE=
AUTH0_ISSUER=

# --- Clerk (Phase 1 rider auth) ---
CLERK_SECRET_KEY=
CLERK_PUBLISHABLE_KEY=
CLERK_WEBHOOK_SIGNING_SECRET=

# --- Email (Gmail SMTP) ---
GMAIL_USER=
GMAIL_APP_PASSWORD=

# --- Google Maps (server-side proxy) ---
GOOGLE_MAPS_API_KEY=
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
TNG_API_KEY=
GRABPAY_API_KEY=
FCM_SERVER_KEY=
GCS_BUCKET=

# --- Storage ---
STORAGE=
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET=
R2_PUBLIC_URL=
