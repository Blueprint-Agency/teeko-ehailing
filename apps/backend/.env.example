# ============================================================
# Teeko backend — example environment
# Copy to .env and fill in. Canonical shape = apps/backend/src/config/env.ts
# (Zod schema) plus the direct process.env reads in src/lib/storage/* and
# src/http/middleware/auth.ts. Keep this file in sync with env.ts.
# ============================================================

# --- Server ---
NODE_ENV=development
PORT=3000
LOG_LEVEL=debug

# --- Database ---
# Local docker-compose maps host 5500 -> container 5432.
DATABASE_URL=postgres://teeko:teeko@localhost:5500/teeko

# --- Redis ---
# Local docker-compose runs redis on 6379 (started by make init).
REDIS_URL=redis://localhost:6379

# --- Clerk (separate instances for rider and driver apps) ---
CLERK_RIDER_SECRET_KEY=
CLERK_RIDER_PUBLISHABLE_KEY=
CLERK_RIDER_WEBHOOK_SIGNING_SECRET=
CLERK_DRIVER_SECRET_KEY=
CLERK_DRIVER_PUBLISHABLE_KEY=
CLERK_DRIVER_WEBHOOK_SIGNING_SECRET=

# --- Email: Gmail SMTP (active provider) ---
GMAIL_USER=
GMAIL_APP_PASSWORD=

# --- Email: Resend (optional fallback; unused while Gmail is active) ---
# Keep RESEND_FROM_EMAIL a valid email — an empty value fails Zod's .email()
# check (the .default() only fires when the var is ABSENT, not when it is "").
RESEND_API_KEY=
RESEND_FROM_EMAIL=onboarding@resend.dev

# --- Auth0 (optional — forward-compat placeholder, not read yet) ---
AUTH0_DOMAIN=
AUTH0_AUDIENCE=
AUTH0_ISSUER=

# --- Google Maps (server-side proxy — never exposed to mobile clients) ---
GOOGLE_MAPS_API_KEY=

# --- Commission & fees ---
# Keep these populated — an empty value coerces to 0 (Zod .default() only fires
# on an absent var, not an empty string).
COMMISSION_RATE=0.10
CANCELLATION_FEE_CENTS=300
CANCELLATION_DRIVER_SHARE=0.5

# --- Payments (teeko-payment-system.md) ---
# STRIPE_SECRET_KEY / TNG_* are OPTIONAL: when unset the backend runs against the
# built-in MOCK gateways (external/stripe.ts, external/tng.ts) so the flow works
# end-to-end locally with no real money.
#
# Set STRIPE_SECRET_KEY to flip on the REAL Stripe gateway. A test key
# (sk_test_...) works — trip charges then land in the Stripe TEST dashboard with
# real pi_... ids. Use sk_live_... only in production.
STRIPE_SECRET_KEY=
# Webhook signing secret for /api/webhooks/stripe. Get it locally from the Stripe
# CLI: `pnpm stripe:listen` prints `whsec_...` on start — paste it here and
# restart the server. Required whenever STRIPE_SECRET_KEY is set, or every
# webhook delivery is rejected with BAD_SIGNATURE.
STRIPE_WEBHOOK_SECRET=
# Stripe Connect platform client id (driver payouts / Express onboarding).
STRIPE_CONNECT_CLIENT_ID=
TNG_MERCHANT_ID=
TNG_API_KEY=
# Payout / cashout rules.
CASHOUT_COOLDOWN_HOURS=24
MIN_CASHOUT_CENTS=1000
# App base URL (Connect onboarding return/refresh deep links) + currency.
APP_URL=https://app.teeko.my
CURRENCY=myr

# --- Storage ---
# STORAGE selects the adapter: 'r2' (active) | 'gcs' (v1.0 stub) | unset = local disk.
STORAGE=
# Cloudflare R2 — active adapter for driver-web document uploads.
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET=
R2_PUBLIC_URL=
# Google Cloud Storage — only when STORAGE=gcs (adapter is a v1.0 stub today).
GCS_BUCKET=

# --- Dev / staging auth bypass (INSECURE — demo only) ---
# DEV_AUTH_BYPASS=true re-enables the X-Teeko-User / X-Teeko-Role header bypass
# even under NODE_ENV=production (i.e. on staging). Keep it 'false' anywhere real
# — anyone can then impersonate any user via a header. (Empty/absent => false.)
DEV_AUTH_BYPASS=false
# DEV_USER_ID / DEV_ROLE back the 'dev-bypass-token' path, active only when
# NODE_ENV != production (local dev).
DEV_USER_ID=
DEV_ROLE=

# --- Not yet wired (future integrations — no env.ts entry / no consumer yet) ---
# Roadmap payment providers + push. Listed for visibility only; add them to
# src/config/env.ts before any code reads them.
GRABPAY_API_KEY=
FCM_SERVER_KEY=
